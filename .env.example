# Your real backend API key (injected silently, never exposed to users)
MASTER_API_KEY=your_real_backend_api_key_here

# Optional: additional backend keys for rotation (comma-separated)
# If set, rotates through these instead of using MASTER_API_KEY for every request
# EVOLINK_KEYS=key1,key2,key3

# Proxy port
PORT=8080
